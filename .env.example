# ── DB 설정 ──
# SQLite (기본값, 단독 컨테이너용)
DATABASE_URL=sqlite:///./nogil_bench.db

# PostgreSQL (docker-compose 사용 시)
# DATABASE_URL=postgresql+psycopg://nogil:nogil-bench-dev@db:5432/nogil_bench

# ── 커넥션 풀 설정 (PostgreSQL 전용) ──
# DB_POOL_SIZE: 풀에 유지하는 상시 커넥션 수 (기본 5)
# DB_MAX_OVERFLOW: 풀이 꽉 찼을 때 추가로 열 수 있는 커넥션 수 (기본 10)
# DB_ECHO: SQL 쿼리 로깅 여부 (기본 false)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# ── 테스트용 PostgreSQL URL (pytest integration 테스트) ──
# TEST_DATABASE_URL=postgresql+psycopg://nogil:nogil-bench-dev@db:5432/nogil_bench_test
